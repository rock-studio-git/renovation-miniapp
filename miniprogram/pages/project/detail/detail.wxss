.detail-header .dh-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.dh-name {
  font-size: 36rpx;
  font-weight: 600;
}
.dh-meta {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}
.stage-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}
.stage-tip {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 12rpx;
}
.budget-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.b-col {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.b-label {
  font-size: 22rpx;
  color: var(--text-placeholder);
}
.budget-bar {
  margin: 8rpx 0 12rpx;
}
.budget-risk {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.budget-usage {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.link {
  font-size: 26rpx;
  color: var(--primary-color);
}
.todo-stats {
  display: flex;
  justify-content: space-around;
  text-align: center;
}
.ts-col {
  display: flex;
  flex-direction: column;
}
.ts-num {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.ts-label {
  font-size: 24rpx;
  color: var(--text-placeholder);
}
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 12rpx;
}
