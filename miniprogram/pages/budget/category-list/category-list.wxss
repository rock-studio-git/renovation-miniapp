.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.add-bar {
  margin-bottom: 24rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.form-field {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #1f2329;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
}

.form-actions {
  display: flex;
  gap: 20rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  padding: 32rpx 0;
}

.cat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.cat-row {
  padding: 4rpx 0;
}

.cat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.cat-name {
  font-size: 30rpx;
  color: #1f2329;
  font-weight: 500;
}

.cat-money {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.cat-money-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-right: 8rpx;
}

.cat-money money-display {
  margin-right: 16rpx;
}

.cat-usage-num {
  font-size: 24rpx;
  color: #1f2329;
  margin-left: 16rpx;
}

.cat-ops {
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
  margin-top: 12rpx;
}

.op-edit {
  font-size: 26rpx;
  color: #07c160;
}

.op-del {
  font-size: 26rpx;
  color: #ee0a24;
}
