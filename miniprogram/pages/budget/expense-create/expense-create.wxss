.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.form-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.form-field {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #1f2329;
  margin-bottom: 12rpx;
}

.req {
  color: #ee0a24;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
}

.form-textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1f2329;
  background: #f5f6f8;
  border-radius: 12rpx;
}

.err {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #ee0a24;
}
