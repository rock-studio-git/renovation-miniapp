.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  padding: 48rpx 0;
}

.exp-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.exp-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.exp-name {
  font-size: 30rpx;
  color: #1f2329;
  font-weight: 500;
}

.exp-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.exp-cat {
  font-size: 26rpx;
  color: #6b7280;
}

.exp-date {
  font-size: 24rpx;
  color: #9ca3af;
}

.exp-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.exp-del {
  font-size: 26rpx;
  color: #ee0a24;
}

.add-btn {
  margin-top: 16rpx;
}
