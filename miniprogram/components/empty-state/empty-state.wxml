<view class="empty">
  <view class="empty-icon">{{icon}}</view>
  <view class="empty-title">{{title}}</view>
  <view class="empty-desc" wx:if="{{desc}}">{{desc}}</view>
  <button
    wx:if="{{showAction && actionText}}"
    class="empty-action"
    size="mini"
    bindtap="onAction"
  >{{actionText}}</button>
</view>
