.risk-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
}
.risk-normal {
  color: #07a24a;
  background: #e8f8ee;
}
.risk-warning {
  color: #d9730a;
  background: #fff1e6;
}
.risk-overspent {
  color: #d92c2c;
  background: #fde8e8;
}
